<Window x:Class="TrccToInfoPanel.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TrccToInfoPanel.Wpf.ViewModels"
        Title="TRCC to InfoPanel Converter" Height="720" Width="1100" MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen" AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
>
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <DockPanel Margin="12">
        <!-- Top: Input/Output/Actions -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <!-- Input row -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Input:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Grid.Column="1" Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                         VerticalAlignment="Center" Padding="4,3"/>
                <Button Grid.Column="2" Content="File..." Command="{Binding BrowseInputCommand}"
                        Padding="12,4" Margin="6,0,0,0"/>
                <Button Grid.Column="3" Content="Folder..." Padding="12,4" Margin="4,0,0,0"
                        Click="BrowseFolderInput_Click"/>
            </Grid>
            <!-- Output row -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Output:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Grid.Column="1" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center" Padding="4,3"/>
                <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseOutputCommand}"
                        Padding="12,4" Margin="6,0,0,0"/>
            </Grid>
            <!-- Mode + Convert button -->
            <DockPanel Margin="0,2,0,0">
                <Button DockPanel.Dock="Right" Content="Convert" Command="{Binding ConvertCommand}"
                        Padding="24,6" FontWeight="SemiBold" FontSize="14" Margin="8,0,0,0"/>
                <TextBlock Text="{Binding ModeDescription}" VerticalAlignment="Center"
                           FontSize="13" Foreground="#888" Margin="70,0,0,0"/>
            </DockPanel>
        </StackPanel>

        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="140" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- Left: Element list -->
            <DockPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="3">
                <TextBlock DockPanel.Dock="Top" Text="Elements" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ListView ItemsSource="{Binding ElementInfos}" FontSize="12"
                          BorderBrush="#DDD" BorderThickness="1">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#" Width="28" DisplayMemberBinding="{Binding Index}"/>
                            <GridViewColumn Header="Type" Width="55" DisplayMemberBinding="{Binding Type}"/>
                            <GridViewColumn Header="Description" Width="110" DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="Position" Width="65" DisplayMemberBinding="{Binding Position}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" Width="6"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- Right top: Visual preview -->
            <DockPanel Grid.Column="2" Grid.Row="0">
                <TextBlock DockPanel.Dock="Top" Text="Preview" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Border BorderBrush="#DDD" BorderThickness="1" Background="#1A1A1A" ClipToBounds="True">
                    <Viewbox Stretch="Uniform">
                        <Grid Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                            <!-- Background image -->
                            <Image Source="{Binding BackgroundImage}" Stretch="Fill"
                                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            <!-- Elements overlay -->
                            <ItemsControl ItemsSource="{Binding PreviewElements}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontFamily="{Binding FontFamily}"
                                                   FontSize="{Binding FontSize}"
                                                   FontWeight="{Binding FontWeight}"
                                                   FontStyle="{Binding FontStyleWpf}"
                                                   Foreground="{Binding ColorBrush}"
                                                   ToolTip="{Binding TypeLabel}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Viewbox>
                </Border>
            </DockPanel>

            <GridSplitter Grid.Column="2" Grid.Row="1" Height="6"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Background="Transparent"/>

            <!-- Right bottom: Log output -->
            <DockPanel Grid.Column="2" Grid.Row="2">
                <TextBlock DockPanel.Dock="Top" Text="Log" FontWeight="SemiBold" Margin="0,4,0,4"/>
                <ListBox x:Name="LogListBox" ItemsSource="{Binding LogMessages}"
                         FontFamily="Consolas" FontSize="11.5"
                         BorderBrush="#DDD" BorderThickness="1"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
